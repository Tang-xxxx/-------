<?xml version="1.0" encoding="UTF-8"?>
<hdevelop file_version="1.2" halcon_version="25.05.0.0">
<procedure name="main">
<interface/>
<body>
<c>* ============================================================</c>
<c>* Badge Relief Height Field V4.1</c>
<c>*</c>
<c>* 全图多尺度浮雕 Height Map</c>
<c>*</c>
<c>* 核心：</c>
<c>*</c>
<c>*   不进行前景分割</c>
<c>*   不使用 Mask</c>
<c>*   不使用 Distance Transform</c>
<c>*</c>
<c>*   直接从整张图片生成高度场</c>
<c>*</c>
<c>*</c>
<c>*   Image</c>
<c>*      │</c>
<c>*      ▼</c>
<c>*    Gray</c>
<c>*      │</c>
<c>*      ├───────────────┐</c>
<c>*      ▼               ▼</c>
<c>*   Large Blur       Small Blur</c>
<c>*      │               │</c>
<c>*      │               ▼</c>
<c>*      │          High Detail</c>
<c>*      │</c>
<c>*      ▼</c>
<c>*   Base Height</c>
<c>*      │</c>
<c>*      │</c>
<c>*      └───────┬───────┐</c>
<c>*              │       │</c>
<c>*              ▼       ▼</c>
<c>*          Mid Detail  High Detail</c>
<c>*              │       │</c>
<c>*              └───┬───┘</c>
<c>*                  ▼</c>
<c>*            Height Fusion</c>
<c>*                  │</c>
<c>*                  ▼</c>
<c>*            Final Height</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<c></c>
<l>dev_update_off ()</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 01. 参数</c>
<c>* ============================================================</c>
<c></c>
<l>ImagePath := 'C:/Users/123321/Desktop/测试图片-浮雕/badge.png'</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 大尺度</c>
<c>*</c>
<c>* 越大：</c>
<c>*</c>
<c>*   越强调整体形状</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>LargeScale := 101</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 中尺度</c>
<c>*</c>
<c>* 控制：</c>
<c>*</c>
<c>*   雕刻结构</c>
<c>*   动物主体</c>
<c>*   面部</c>
<c>*   翅膀</c>
<c>*   大纹理</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>MiddleScale := 31</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 小尺度</c>
<c>*</c>
<c>* 控制：</c>
<c>*</c>
<c>*   毛发</c>
<c>*   羽毛</c>
<c>*   细纹</c>
<c>*   雕刻细节</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>SmallScale := 7</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 高度权重</c>
<c>* ============================================================</c>
<c></c>
<l>BaseWeight := 1.0</l>
<c></c>
<l>MiddleWeight := 0.8</l>
<c></c>
<l>HighWeight := 0.25</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 02. 读取图像</c>
<c>* ============================================================</c>
<c></c>
<l>read_image (Image, ImagePath)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 03. 获取图像尺寸</c>
<c>* ============================================================</c>
<c></c>
<l>get_image_size (Image, \
                ImageWidth, \
                ImageHeight)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 04. 创建窗口</c>
<c>* ============================================================</c>
<c></c>
<l>dev_open_window (0, \
                 0, \
                 ImageWidth / 2, \
                 ImageHeight / 2, \
                 'black', \
                 WindowHandle)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 05. 显示原图</c>
<c>* ============================================================</c>
<c></c>
<l>dev_display (Image)</l>
<c></c>
<l>stop ()</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 06. RGB → Gray</c>
<c>* ============================================================</c>
<c></c>
<l>count_channels (Image, \
                Channels)</l>
<c></c>
<c></c>
<l>if (Channels == 3)</l>
<c></c>
<l>    rgb1_to_gray (Image, \
                  Gray)</l>
<c></c>
<l>else</l>
<c></c>
<l>    Gray := Image</l>
<c></c>
<l>endif</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 07. 显示 Gray</c>
<c>* ============================================================</c>
<c></c>
<l>dev_display (Gray)</l>
<c></c>
<l>stop ()</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 08. 大尺度 Blur</c>
<c>*</c>
<c>* 作用：</c>
<c>*</c>
<c>*   获取整体亮度 / 大结构</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>mean_image (Gray, \
            LargeBlur, \
            LargeScale, \
            LargeScale)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 09. 大结构作为 Base Height</c>
<c>*</c>
<c>* Gray 原始范围：</c>
<c>*</c>
<c>*   0 ~ 255</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>scale_image (LargeBlur, \
             BaseHeight, \
             BaseWeight, \
             0)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 10. 中尺度 Blur</c>
<c>* ============================================================</c>
<c></c>
<l>mean_image (Gray, \
            MiddleBlur, \
            MiddleScale, \
            MiddleScale)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 11. 中尺度 Detail</c>
<c>*</c>
<c>* Gray - MiddleBlur</c>
<c>*</c>
<c>* 保留正负变化</c>
<c>*</c>
<c>* 亮：</c>
<c>*</c>
<c>*   正值</c>
<c>*</c>
<c>* 暗：</c>
<c>*</c>
<c>*   负值</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>sub_image (Gray, \
           MiddleBlur, \
           MiddleDetail, \
           1.0, \
           0)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 12. 中尺度 Detail 加权</c>
<c>* ============================================================</c>
<c></c>
<l>scale_image (MiddleDetail, \
             MiddleDetailWeighted, \
             MiddleWeight, \
             0)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 13. 小尺度 Blur</c>
<c>* ============================================================</c>
<c></c>
<l>mean_image (Gray, \
            SmallBlur, \
            SmallScale, \
            SmallScale)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 14. 高频 Detail</c>
<c>*</c>
<c>* Gray - SmallBlur</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>sub_image (Gray, \
           SmallBlur, \
           HighDetail, \
           1.0, \
           0)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 15. 高频 Detail 加权</c>
<c>* ============================================================</c>
<c></c>
<l>scale_image (HighDetail, \
             HighDetailWeighted, \
             HighWeight, \
             0)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 16. Base + Middle</c>
<c>*</c>
<c>* 注意：</c>
<c>*</c>
<c>* 不进行 normalize</c>
<c>*</c>
<c>* 保留原始相对关系</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>add_image (BaseHeight, \
           MiddleDetailWeighted, \
           BaseMiddleHeight, \
           1.0, \
           0)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 17. Base + Middle + High</c>
<c>* ============================================================</c>
<c></c>
<l>add_image (BaseMiddleHeight, \
           HighDetailWeighted, \
           HeightRaw, \
           1.0, \
           0)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 18. 查看原始 Height 范围</c>
<c>*</c>
<c>* 这里非常重要</c>
<c>*</c>
<c>* 用于确认算法是否真的产生高度变化</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>min_max_gray (HeightRaw, \
              HeightRaw, \
              0, \
              MinHeight, \
              MaxHeight, \
              RangeHeight)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 19. 显示高度范围</c>
<c>* ============================================================</c>
<c></c>
<l>dev_inspect_ctrl ([MinHeight, \
                   MaxHeight, \
                   RangeHeight])</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 20. 最终归一化</c>
<c>*</c>
<c>* 只在最后一步做一次</c>
<c>*</c>
<c>* ============================================================</c>
<c></c>
<l>scale_image_range (HeightRaw, \
                   FinalHeightMap, \
                   0, \
                   255)</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 21. 显示最终 Height Map</c>
<c>* ============================================================</c>
<c></c>
<l>dev_display (FinalHeightMap)</l>
<c></c>
<c></c>
<l>stop ()</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 22. 保存 8-bit Height Map</c>
<c>* ============================================================</c>
<c></c>
<l>write_image (FinalHeightMap, \
             'tiff', \
             0, \
             'C:/Users/123321/Desktop/测试图片-浮雕/Badge_Height_V4_1_8bit.tif')</l>
<c></c>
<c></c>
<c>* ============================================================</c>
<c>* 23. 转换 16-bit</c>
<c>* ============================================================</c>
<c></c>
<l>convert_image_type (FinalHeightMap, \
                    HeightMap16, \
                    'uint2')</l>
<c></c>
<c></c>
<l>dev_update_on ()</l>
</body>
<docu id="main">
<parameters/>
</docu>
</procedure>
</hdevelop>
